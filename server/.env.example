# ── chataggr server config ───────────────────────────────────────────────
# Copy to ".env" and fill in. chataggr is now a multi-user service: channels
# are managed per-user in the dashboard, NOT here.

# HTTP + WebSocket port
PORT=8080

# PostgreSQL connection string. Matches docker-compose.yml defaults.
DATABASE_URL=postgres://chataggr:chataggr@localhost:5432/chataggr

# Secret used to sign session cookies. CHANGE THIS in production
# (e.g. `openssl rand -hex 32`).
SESSION_SECRET=dev-insecure-change-me

# Set true behind HTTPS so session cookies are marked Secure.
COOKIE_SECURE=false

# ── split deploy (frontend on a different origin, e.g. Vercel) ───────────────
# Only needed when the frontend is hosted separately from this API. For an
# integrated deploy (this server serves the built frontend) leave these unset.
#
# Browser origin(s) allowed to call this API with credentials (comma-separated),
# e.g. https://rokit.vercel.app
CORS_ORIGIN=
# Cross-site cookies require SameSite=None (which also forces Secure). Use
# "none" for the split; leave "lax" for same-origin. Requires HTTPS on both.
COOKIE_SAMESITE=lax

# ── Twitch OAuth ("Login with Twitch") ──────────────────────────────────────
# Optional. If unset, only email/password login is offered.
# Register an app at https://dev.twitch.tv/console/apps and set the OAuth
# redirect URL to <OAUTH_REDIRECT_BASE>/api/auth/twitch/callback.
# OAUTH_REDIRECT_BASE is THIS API's public URL (where the callback lands).
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:8080

# ── email (verification + password reset) ───────────────────────────────────
# Public base URL of the FRONTEND. Used in email links AND for the overlay URL
# and post-OAuth redirects. In dev with the Vite server, set http://localhost:5173.
# In a split deploy, set your frontend origin (e.g. https://rokit.vercel.app).
APP_URL=http://localhost:8080

# SMTP. If SMTP_HOST is blank, emails are PRINTED TO THE SERVER CONSOLE instead
# of sent — handy for local testing. Fill these in to send real mail (e.g. via
# SendGrid, Mailgun, Postmark, Resend SMTP, or your own server).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=chataggr <no-reply@chataggr.local>

# ── tuning ───────────────────────────────────────────────────────────────
# Recent messages replayed to a freshly-opened overlay/preview.
BACKLOG_SIZE=50
# How long a user's platform connections stay open after their last
# overlay/preview disconnects, before tearing down (ms).
HUB_IDLE_MS=60000
# Abuse guard: max chat sources a single user can add.
MAX_SOURCES_PER_USER=25

# Proxy hops to trust for the real client IP (rate limiting). Railway/most
# PaaS = 1. Set 0 for direct/local with no proxy in front.
TRUST_PROXY=1
