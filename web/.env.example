# ── Rokit frontend build config ──────────────────────────────────────────────
# Only needed for a SPLIT deploy where the frontend (this app) is hosted
# separately from the API/WebSocket backend — e.g. frontend on Vercel, backend
# on Railway. Set this to the backend's public origin (no trailing slash):
#
#   VITE_API_BASE=https://your-backend.up.railway.app
#
# Vite inlines VITE_* vars at BUILD time, so set it in your host's env (Vercel
# Project → Settings → Environment Variables) and rebuild after changes.
#
# Leave unset for an integrated deploy (the Node server serves this frontend):
# all API/WS calls then stay relative/same-origin.
VITE_API_BASE=
